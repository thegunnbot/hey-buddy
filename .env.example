# Anthropic (required for AI chat)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot (required for standalone bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_RICH_ID=

# Server
PORT=3001

# Auth (leave false for local dev; set true + add Auth0 details for production)
AUTH_ENABLED=false
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# Sports integration — football-data.org (free tier, covers PL/Championship/internationals)
# Get key at: https://www.football-data.org/client/register
# Free tier: 10 req/min. Used for Chelsea FC and England fixtures.
FOOTBALL_DATA_API_KEY=

# Machine-to-machine API key (for agent-to-agent access e.g. TheGunnBot → Hey Buddy)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEYBUDDY_API_KEY=
